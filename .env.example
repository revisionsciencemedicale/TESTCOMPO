# Copie ce fichier en .env si tu testes localement.
# Récupère cette URL dans Neon > Project > Dashboard > Connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
PGSSLMODE=require
SESSION_TIMEOUT_MS=0
PORT=3000

# Synchronisation des comptes avec GitHub
# Créer un token GitHub fine-grained avec accès Contents: Read and Write sur le dépôt.
GITHUB_TOKEN=
GITHUB_REPO=ton-utilisateur/ton-depot
GITHUB_BRANCH=main
GITHUB_USERS_PATH=server-data/app_users_store.json
